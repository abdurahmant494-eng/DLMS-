<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.text.Font?>

<VBox xmlns="http://javafx.com/javafx" 
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.borana.dlms.controllers.LoginController"
      spacing="20" 
      alignment="CENTER"
      style="-fx-background-color: #f5f5f5; -fx-padding: 40;">
    
    <!-- Header -->
    <VBox spacing="10" alignment="CENTER">
        <Label text="DLMS" style="-fx-text-fill: #2c3e50;">
            <font>
                <Font name="System Bold" size="36" />
            </font>
        </Label>
        <Label text="Digital Library Management System" style="-fx-text-fill: #7f8c8d;">
            <font>
                <Font name="System" size="14" />
            </font>
        </Label>
    </VBox>
    
    <!-- Login Form -->
    <GridPane hgap="10" vgap="15" alignment="CENTER">
        <padding><Insets top="20" right="20" bottom="20" left="20"/></padding>
        
        <!-- Email -->
        <Label text="Email:" GridPane.rowIndex="0" GridPane.columnIndex="0" />
        <TextField fx:id="emailField" promptText="Enter your email" 
                   GridPane.rowIndex="0" GridPane.columnIndex="1" 
                   prefWidth="250" />
        
        <!-- Password -->
        <Label text="Password:" GridPane.rowIndex="1" GridPane.columnIndex="0" />
        <PasswordField fx:id="passwordField" promptText="Enter your password" 
                      GridPane.rowIndex="1" GridPane.columnIndex="1" 
                      prefWidth="250" />
        
        <!-- Error Message -->
        <Label fx:id="errorLabel" text="" style="-fx-text-fill: red;" 
               GridPane.rowIndex="2" GridPane.columnIndex="0" GridPane.columnSpan="2" 
               visible="false" />
    </GridPane>
    
    <!-- Buttons -->
    <HBox spacing="20" alignment="CENTER">
        <Button text="Login" fx:id="loginButton" 
                style="-fx-background-color: #3498db; -fx-text-fill: white; -fx-font-weight: bold;"
                onAction="#handleLogin"
                prefWidth="100" prefHeight="40" />
        
        <Button text="Exit" fx:id="exitButton" 
                style="-fx-background-color: #95a5a6; -fx-text-fill: white;"
                onAction="#handleExit"
                prefWidth="100" prefHeight="40" />
    </HBox>
    
    <!-- Footer -->
    <Label text="Version 1.0.0 - For Librarian Use Only" 
           style="-fx-text-fill: #bdc3c7; -fx-font-size: 10px;" />
</VBox>